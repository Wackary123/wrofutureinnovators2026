from google import genai
from openai import OpenAI
import sounddevice as sd
import lameenc
import os

# ✅ FIXED KEY NAME
open_ai_client = OpenAI(api_key="YOUR_OPENAI_KEY")
google_client = genai.Client(api_key="YOUR_GEMINI_KEY")

# 🎤 RECORD AUDIO
def record_to_mp3(filename="recording.mp3", duration=5, samplerate=44100, channels=1):
    print(f"\n🎤 Recording for {duration} seconds...")
    audio_data = sd.rec(int(duration * samplerate), samplerate=samplerate, channels=channels, dtype='int16')
    sd.wait()
    print("✅ Recording finished.")

    encoder = lameenc.Encoder()
    encoder.set_bit_rate(128)
    encoder.set_in_sample_rate(samplerate)
    encoder.set_channels(channels)
    encoder.set_quality(2)

    mp3_data = encoder.encode(audio_data.tobytes())
    mp3_data += encoder.flush()

    with open(filename, "wb") as f:
        f.write(mp3_data)

# 🧠 STT (Whisper)
def generate_transcription(file_path):
    try:
        with open(file_path, "rb") as audio_file:
            transcription = open_ai_client.audio.transcriptions.create(
                model="gpt-4o-transcribe",
                file=audio_file
            )
        return transcription.text
    except Exception as e:
        print("❌ Transcription error:", e)
        return ""

# 🤖 Gemini response
def get_gemini_answer(transcription):
    try:
        prompt = f"""
You are a friendly museum robot guide.

The user said: "{transcription}"

Rules:
- Respond in the SAME language
- Keep answers SHORT (1-2 sentences)
- Be clear and engaging like a real guide
"""
        response = google_client.models.generate_content(
            model="gemini-3-flash-preview",
            contents=prompt
        )
        return response.text
    except Exception as e:
        print("❌ Gemini error:", e)
        return "Sorry, I couldn't process that."

# 🔊 TTS (OpenAI)
def speak(text):
    try:
        speech = open_ai_client.audio.speech.create(
            model="gpt-4o-mini-tts",
            voice="alloy",
            input=text
        )

        with open("response.mp3", "wb") as f:
            f.write(speech.read())

        # ▶️ AUTO PLAY
        os.system("mpg123 response.mp3")

    except Exception as e:
        print("❌ TTS error:", e)

# 🔁 MAIN LOOP
def main():
    while True:
        record_to_mp3("recording.mp3", duration=5)

        transcription = generate_transcription("recording.mp3")

        if not transcription:
            continue

        print("🧍 You said:", transcription)

        answer = get_gemini_answer(transcription)
        print("🤖 Robot:", answer)

        speak(answer)

# ▶️ RUN
if __name__ == "__main__":
    main()